# BagyGo Backend Environment Variables (TEMPLATE)
# Copy this file to .env and fill in your real keys

# Server Configuration
PORT=8080

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/bagygo
DB_USERNAME=root
DB_PASSWORD=

# Security Configuration (JWT)
# Use a long random string (~32+ characters)
JWT_SECRET=your_super_secret_jwt_key_here

# Payment Configuration (Stripe)
# Secret key from Stripe Dashboard (sk_test_...)
STRIPE_API_KEY=sk_test_your_secret_key
# Webhook secret from Stripe CLI or Dashboard (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
